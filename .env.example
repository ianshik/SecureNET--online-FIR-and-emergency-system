# ==========================================
# SecureNet NP-SERP Environment Variables
# ==========================================

# --- API Server (Express) ---
PORT=5000
NODE_ENV=development

# --- Database ---
MONGO_URI=mongodb://localhost:27017/securenet
REDIS_URL=redis://localhost:6379

# --- Authentication & Security ---
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_access_token_here
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# --- Third-Party Integrations ---
# AWS S3 (Evidence Management)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=securenet-evidence-bucket

# AI Assistant (Claude / OpenAI)
AI_PROVIDER=anthropic # or openai
ANTHROPIC_API_KEY=your_claude_api_key
OPENAI_API_KEY=your_openai_api_key

# Communications (Nodemailer / SMS)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
TWILIO_ACCOUNT_SID=mock_account_sid
TWILIO_AUTH_TOKEN=mock_auth_token
TWILIO_PHONE_NUMBER=+1234567890
