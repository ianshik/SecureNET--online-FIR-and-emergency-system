{
  "openapi": "3.0.0",
  "info": {
    "title": "SecureNet NP-SERP API",
    "version": "1.0.0",
    "description": "API documentation for the National Public Safety & Emergency Response Platform"
  },
  "servers": [
    {
      "url": "http://localhost:5000",
      "description": "Local server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "firstName": { "type": "string" },
                  "lastName": { "type": "string" },
                  "email": { "type": "string" },
                  "phone": { "type": "string" },
                  "password": { "type": "string" },
                  "role": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User created" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful" }
        }
      }
    },
    "/api/sos/trigger": {
      "post": {
        "summary": "Trigger an SOS emergency",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "coordinates": {
                    "type": "array",
                    "items": { "type": "number" },
                    "example": [77.2090, 28.6139]
                  },
                  "servicesRequired": {
                    "type": "array",
                    "items": { "type": "string" },
                    "example": ["POLICE", "AMBULANCE"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "SOS triggered and dispatched" }
        }
      }
    }
  }
}
